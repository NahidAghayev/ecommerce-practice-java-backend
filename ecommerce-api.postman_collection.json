{
  "info": {
    "name": "E-Commerce API",
    "description": "Comprehensive test collection for Phase 1 Step 12 review. Covers all 16 endpoints, happy paths, error paths, security rules, pagination, filtering, order state machine, and ownership checks.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "const url = pm.request.url.toString();",
          "const method = pm.request.method;",
          "const name = pm.info.requestName || '';",
          "",
          "if (url.includes('/api/auth/')) return;",
          "if (name.includes('(401)') || name.includes('No Token') || name.includes('Wrong Password') || name.includes('Duplicate Email')) return;",
          "",
          "let tokenKey;",
          "if (",
          "    (url.includes('/api/users') && !name.includes('User Accesses')) ||",
          "    (url.includes('/api/products') && (method === 'POST' || method === 'PUT') && !name.includes('Forbidden')) ||",
          "    (url.includes('/api/orders/') && url.includes('/status') && !name.includes('Forbidden'))",
          ") {",
          "    tokenKey = 'admin_token';",
          "} else if (name.includes('Other User')) {",
          "    tokenKey = 'other_user_token';",
          "} else {",
          "    tokenKey = 'user_token';",
          "}",
          "",
          "const token = pm.environment.get(tokenKey) || pm.globals.get(tokenKey);",
          "if (token) {",
          "    pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + token });",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "item": [
    {
      "name": "Auth & User Setup",
      "description": "Bootstrap users and obtain JWT tokens for subsequent requests. Run these first.",
      "item": [
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "url": "{{base_url}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"{{admin_email}}\", \"password\": \"{{admin_password}}\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 201 or user exists\", () => pm.expect(pm.response.code).to.be.oneOf([201, 400]));",
                  "const json = pm.response.json();",
                  "pm.test(\"Save token on success\", () => {",
                  "    if (pm.response.code === 201) {",
                  "        pm.expect(json.success).to.be.true;",
                  "        pm.expect(json.data).to.have.property(\"token\");",
"        pm.environment.set(\"admin_token\", json.data.token); pm.globals.set(\"admin_token\", json.data.token);",
        "        pm.expect(json).to.have.all.keys(\"success\", \"data\", \"message\", \"timestamp\");",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
