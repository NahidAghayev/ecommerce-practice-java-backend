    {
      "name": "Order Status State Machine",
      "description": "Test valid transitions, invalid transitions, cancellation with stock restoration, and role enforcement.",
      "item": [
        {
          "name": "Cancel Order 2 (PENDING→CANCELLED, stock restored)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json", "type": "text" }
            ],
            "url": "{{base_url}}/api/orders/{{order_2_id}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\"status\": \"CANCELLED\"}"
            }
          },
          "event": [
